PORT=8800
NODE_ENV=production

# ── Firebase client-side (used by login.ejs in browser) ──────────────────────
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── Firebase Admin SDK (paste entire serviceAccountKey.json as one line) ─────
# To generate: cat serviceAccountKey.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT=

# ── External APIs ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
CODEFORCE_API_KEY=
CODEFORCE_API_SECRET=
