<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= problem ? problem.name : 'Playground' %> — CP Platform</title>
    
  <!-- Monaco loader -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs/loader.min.js"></script>
    <%- include('./partials/head') %>
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d0f11;
      --surface:   #141618;
      --surface2:  #1c1f22;
      --border:    #2a2d31;
      --accent:    #4ade80;
      --accent2:   #60a5fa;
      --warn:      #fbbf24;
      --danger:    #f87171;
      --text:      #e2e4e8;
      --muted:     #6b7280;
      --font-ui:   'DM Sans', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      --radius:    6px;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-ui);
      font-size: 14px;
      overflow: hidden;
    }

    /* ── Layout ── */
    .app {
      display: grid;
      grid-template-rows: 44px 1fr;
      grid-template-columns: 1fr 1fr;
      height: 100vh;
    }

    /* ── Topbar ── */
    .topbar {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 0 16px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
    }

    .topbar-logo {
      font-family: var(--font-mono);
      font-weight: 500;
      font-size: 13px;
      color: var(--accent);
      letter-spacing: 0.04em;
      margin-right: 4px;
    }

    .problem-name {
      font-size: 13px;
      font-weight: 500;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 260px;
    }

    .problem-meta {
      font-size: 12px;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .tag {
      padding: 2px 7px;
      border-radius: 4px;
      background: var(--surface2);
      border: 1px solid var(--border);
      font-size: 11px;
      color: var(--muted);
    }

    .rating-badge {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--accent);
      padding: 2px 7px;
      border-radius: 4px;
      background: rgba(74, 222, 128, 0.08);
      border: 1px solid rgba(74, 222, 128, 0.2);
    }

    .topbar-right {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .user-badge {
      font-size: 12px;
      color: var(--muted);
      padding: 3px 10px;
      border: 1px solid var(--border);
      border-radius: 20px;
    }

    .btn-link {
      font-size: 12px;
      color: var(--accent2);
      background: none;
      border: none;
      cursor: pointer;
      text-decoration: none;
    }
    .btn-link:hover { text-decoration: underline; }

    /* ── Editor Panel (left) ── */
    .editor-panel {
      display: flex;
      flex-direction: column;
      border-right: 1px solid var(--border);
      overflow: hidden;
    }

    .editor-toolbar {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      flex-wrap: wrap;
    }

    .lang-btn {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 4px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.15s;
    }
    .lang-btn:hover { color: var(--text); border-color: #444; }
    .lang-btn.active {
      background: var(--accent);
      color: #061206;
      border-color: var(--accent);
      font-weight: 500;
    }

    .sep {
      width: 1px;
      height: 18px;
      background: var(--border);
      margin: 0 2px;
    }

    .btn {
      font-family: var(--font-ui);
      font-size: 12px;
      font-weight: 500;
      padding: 4px 14px;
      border-radius: var(--radius);
      border: 1px solid transparent;
      cursor: pointer;
      transition: opacity 0.15s, transform 0.1s;
      white-space: nowrap;
    }
    .btn:active:not(:disabled) { transform: scale(0.97); }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }

    #btn-run    { background: var(--accent);  color: #061206; border-color: var(--accent); }
    #btn-submit { background: var(--accent2); color: #06101f; border-color: var(--accent2); }
    #btn-analyze, #btn-gen-tests {
      background: var(--surface2);
      color: var(--text);
      border-color: var(--border);
    }
    #btn-analyze:hover, #btn-gen-tests:hover { border-color: #555; }

    .hidden { display: none !important; }

    #monaco-container {
      flex: 1;
      min-height: 0;
    }

    /* ── Right Panel ── */
    .right-panel {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      position: relative;
    }

    .io-section {
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    .section-title {
      font-size: 10px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
    }

    #output-status {
      font-size: 11px;
      font-family: var(--font-mono);
      padding: 2px 8px;
      border-radius: 4px;
      margin-left: auto;
    }
    #output-status.success { color: var(--accent);  background: rgba(74,222,128,0.08); }
    #output-status.error   { color: var(--danger);  background: rgba(248,113,113,0.08); }
    #output-status.warn    { color: var(--warn);    background: rgba(251,191,36,0.08); }
    #output-status.neutral { color: var(--muted); }

    #stdin-input {
      flex: 1;
      width: 100%;
      background: var(--surface2);
      color: var(--text);
      font-family: var(--font-mono);
      font-size: 13px;
      line-height: 1.65;
      border: none;
      outline: none;
      resize: none;
      padding: 12px 14px;
      min-height: 0;
    }
    #stdin-input::placeholder { color: var(--muted); }

    #output-content {
      flex: 1;
      overflow-y: auto;
      padding: 12px 14px;
      font-family: var(--font-mono);
      font-size: 13px;
      line-height: 1.65;
      white-space: pre-wrap;
      word-break: break-word;
      background: var(--bg);
      color: var(--text);
      min-height: 0;
    }
    #output-content.error { color: var(--danger); }
    #output-content.warn  { color: var(--warn); }
    #output-content.empty { color: var(--muted); font-style: italic; }

    .divider { height: 1px; background: var(--border); flex-shrink: 0; }

    /* ── AI Panel ── */
    #ai-panel {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 62%;
      background: var(--surface);
      border-top: 2px solid var(--accent);
      display: flex;
      flex-direction: column;
      transform: translateY(100%);
      transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 20;
    }
    #ai-panel.open { transform: translateY(0); }

    .ai-header {
      display: flex;
      align-items: center;
      padding: 8px 14px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      gap: 8px;
    }

    .ai-label {
      font-size: 10px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--accent);
    }

    .ai-tabs { display: flex; gap: 4px; margin-left: 8px; }

    .ai-tab {
      font-size: 11px;
      padding: 2px 10px;
      border-radius: 4px;
      border: 1px solid var(--border);
      background: none;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.12s;
    }
    .ai-tab.active {
      background: var(--surface2);
      color: var(--text);
      border-color: #555;
    }

    #btn-close-ai {
      margin-left: auto;
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      font-size: 16px;
      line-height: 1;
      padding: 2px 4px;
      transition: color 0.12s;
    }
    #btn-close-ai:hover { color: var(--text); }

    #ai-panel-content {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
      font-size: 13px;
      line-height: 1.75;
      color: var(--text);
    }

    .ai-loading {
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--muted);
      padding: 8px 0;
    }

    .ai-spinner {
      width: 14px; height: 14px;
      border: 2px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      flex-shrink: 0;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .ai-empty { color: var(--muted); font-style: italic; }
    .ai-error  { color: var(--danger); }

    #ai-panel-content code {
      font-family: var(--font-mono);
      background: var(--surface2);
      padding: 1px 5px;
      border-radius: 3px;
      font-size: 12px;
      color: var(--accent2);
    }

    #ai-panel-content strong { color: var(--text); font-weight: 500; }

    /* Test case cards */
    .test-card {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 10px;
      overflow: hidden;
    }

    .test-card-header {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 10px;
      border-bottom: 1px solid var(--border);
    }

    .test-number {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--accent);
      font-weight: 500;
    }

    .test-desc {
      font-size: 11px;
      color: var(--muted);
      flex: 1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .btn-use {
      font-size: 11px;
      padding: 2px 9px;
      border-radius: 4px;
      border: 1px solid var(--border);
      background: none;
      color: var(--accent2);
      cursor: pointer;
      transition: border-color 0.12s;
    }
    .btn-use:hover { border-color: var(--accent2); }

    .test-body {
      font-family: var(--font-mono);
      font-size: 12px;
      padding: 8px 10px;
      color: var(--text);
      white-space: pre-wrap;
      word-break: break-all;
    }

    /* ── Toast ── */
    #toast-container {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      z-index: 100;
      pointer-events: none;
    }

    .toast {
      font-size: 12px;
      padding: 7px 18px;
      border-radius: 20px;
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--text);
      opacity: 0;
      transform: translateY(6px);
      transition: opacity 0.2s, transform 0.2s;
      white-space: nowrap;
    }
    .toast.visible       { opacity: 1; transform: translateY(0); }
    .toast.toast-success { border-color: var(--accent);  color: var(--accent); }
    .toast.toast-warn    { border-color: var(--warn);    color: var(--warn); }
    .toast.toast-error   { border-color: var(--danger);  color: var(--danger); }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #444; }
  </style>
</head>

<body>
<div class="app">

  <!-- ─── Topbar ─────────────────────────────────────────── -->
  <header class="topbar">
    <a href="\" class="topbar-logo">cp//</a>

    <% if (problem) { %>
      <span class="problem-name"><%= problem.name %></span>
      <div class="problem-meta">
        <% if (problem.rating) { %>
          <span class="rating-badge"><%= problem.rating %></span>
        <% } %>
        <% if (problem.tags && problem.tags.length) { %>
          <% problem.tags.slice(0, 3).forEach(function(tag) { %>
            <span class="tag"><%= tag %></span>
          <% }) %>
        <% } %>
        <a href="<%= problem.url %>" target="_blank">
  Solve on Codeforces
</a>

      </div>
    <% } else { %>
      <span class="problem-name" style="color: var(--muted);">Playground</span>
    <% } %>

    <div class="topbar-right">
      <% if (user) { %>
        <span class="user-badge"><%= user.email %></span>
        <a href="/logout" class="btn-link" style="color: var(--muted); font-size:11px;">logout</a>
      <% } else { %>
        <a href="/user/login" class="btn-link">Login to submit</a>
      <% } %>
    </div>
  </header>

  <!-- ─── Editor Panel (left) ─────────────────────────── -->
  <section class="editor-panel">
    <div class="editor-toolbar">

      <!-- Language selector -->
      <button class="lang-btn active" data-lang="cpp">C++</button>
      <button class="lang-btn" data-lang="python">Python</button>
      <button class="lang-btn" data-lang="java">Java</button>
      <button class="lang-btn" data-lang="c">C</button>
      <button class="lang-btn" data-lang="rust">Rust</button>

      <div class="sep"></div>

      <!-- Run always visible -->
      <button class="btn" id="btn-run" href="\execute">Run &nbsp;(Ctrl+↵)</button>

      <!-- Submit + AI: rendered only for logged-in users -->
      <% if (user) { %>
        <button class="btn" id="btn-submit">Submit</button>
        <div class="sep"></div>
        <button class="btn" id="btn-analyze">Analyze Code</button>
        <button class="btn" id="btn-gen-tests">Gen Tests</button>
      <% } %>

    </div>

    <!-- Monaco mounts here -->
    <div id="monaco-container"></div>
  </section>

  <!-- ─── Right Panel: stdin / stdout ──────────────────── -->
  <section class="right-panel">

    <!-- stdin -->
    <div class="io-section" style="flex: 0 0 32%;">
      <div class="section-header">
        <span class="section-title">stdin</span>
        <span style="font-size:11px; color: var(--muted); margin-left:auto;">custom input</span>
      </div>
      <textarea
        id="stdin-input"
        placeholder="Paste test input here..."
        spellcheck="false"
        autocomplete="off"
      ></textarea>
    </div>

    <div class="divider"></div>

    <!-- stdout -->
    <div class="io-section" style="flex: 1;">
      <div class="section-header">
        <span class="section-title">output</span>
        <span id="output-status"></span>
      </div>
      <div id="output-content" class="empty">Run your code to see output here.</div>
    </div>

    <!-- AI Panel — slides up over output when open -->
    <div id="ai-panel">
      <div class="ai-header">
        <span class="ai-label">AI Assistant</span>
        <div class="ai-tabs">
          <button class="ai-tab active" id="tab-analysis"
            onclick="handleAITabClick('analysis')">Analysis</button>
          <button class="ai-tab" id="tab-tests"
            onclick="handleAITabClick('tests')">Test Cases</button>
        </div>
        <button id="btn-close-ai" title="Close">✕</button>
      </div>
      <div id="ai-panel-content">
        <p class="ai-empty">Use "AI Analyze" or "Gen Tests" to get started.</p>
      </div>
    </div>

  </section>

</div><!-- /.app -->

<!-- Toast container -->
<div id="toast-container"></div>

<!-- ─── Inject server-side state for editor.js ───────────── -->
<script>
  window.__USER__ = <%= user ? 'true' : 'false' %>;
  window.__PROBLEM_ID__ = <%- problem ? `'${problem.id}'` : 'null' %>;
</script>

<!-- ─── Your editor.js ──────────────────────────────────── -->
<script src="/editor.js"></script>

<!-- ─── AI tab switcher ─────────────────────────────────── -->
<script>
  function handleAITabClick(tab) {
    document.getElementById('tab-analysis').classList.toggle('active', tab === 'analysis');
    document.getElementById('tab-tests').classList.toggle('active', tab === 'tests');
    state.activeAITab = tab;

    // Use cached result if available, otherwise fetch fresh
    if (tab === 'analysis' && state.lastAnalysis) {
      renderAnalysis(state.lastAnalysis);
      return;
    }
    if (tab === 'tests' && state.lastTests) {
      renderGeneratedTests(state.lastTests);
      return;
    }

    if (tab === 'analysis') handleAnalyze();
    else handleGenerateTests();
  }
</script>

</body>
</html>
